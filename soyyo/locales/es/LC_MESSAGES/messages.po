#: argparse.py:242
#, python-format
msgid "%(heading)s:"
msgstr "%(heading)s:"

#: argparse.py:321
msgid "usage: "
msgstr "uso: "

#: argparse.py:752
#, python-format
msgid " (default: %(default)s)"
msgstr " (predeterminado: %(default)s)"

#: argparse.py:814
#, python-format
msgid "argument %(argument_name)s: %(message)s"
msgstr "argumento %(argument_name)s: %(message)s"

#: argparse.py:1189
msgid "show program's version number and exit"
msgstr "muestra la versión y termina"


#: argparse.py:1303
#, python-format
msgid "unknown parser %(parser_name)r (choices: %(choices)s)"
msgstr "analizador %(parser_name)r desconocido (opciones: %(choices)s)"

#: argparse.py:1307
#, python-format
msgid "command '%(parser_name)s' is deprecated"
msgstr "orden '%(parser_name)s' es obsoleta"

#: argparse.py:1374
#, python-format
msgid "argument \"-\" with mode %r"
msgstr "argumento \"-\" con modo %r"

#: argparse.py:1383
#, python-format
msgid "can't open '%(filename)s': %(error)s"
msgstr "no se puede abrir '%(filename)s': %(error)s"

#: argparse.py:1721
#, python-format
msgid "conflicting option string: %s"
msgid_plural "conflicting option strings: %s"
msgstr[0] "literal de opción en conflicto: %s"
msgstr[1] "literales de opción en conflicto: %s"

#: argparse.py:1901
msgid "positional arguments"
msgstr "argumentos posicionales"

#: argparse.py:1902
msgid "options"
msgstr "opciones"

#: argparse.py:1917
msgid "show this help message and exit"
msgstr "Muestra este mensaje de ayuda y termina"

#: argparse.py:1954
msgid "subcommands"
msgstr "subórdenes"

#: argparse.py:2003
#: argparse.py:2566
#, python-format
msgid "unrecognized arguments: %s"
msgstr "argumentos no reconocidos: %s"

#: argparse.py:2109
#, python-format
msgid "not allowed with argument %s"
msgstr "no se permite con el argumento %s"

#: argparse.py:2128
#, python-format
msgid "ambiguous option: %(option)s could match %(matches)s"
msgstr "opción ambigua: %(option)s podría corresponder con %(matches)s"

#: argparse.py:2160
#: argparse.py:2192
#, python-format
msgid "ignored explicit argument %r"
msgstr "argumento explícito %r ignorado"

#: argparse.py:2212
#, python-format
msgid "option '%(option)s' is deprecated"
msgstr "opción '%(option)s' es obsoleta"

#: argparse.py:2244
#, python-format
msgid "argument '%(argument_name)s' is deprecated"
msgstr "argumento' %(argument_name)s' es obsoleto"

#: argparse.py:2337
#, python-format
msgid "the following arguments are required: %s"
msgstr "los siguientes argumentos son necesarios: %s"

#: argparse.py:2352
#, python-format
msgid "one of the arguments %s is required"
msgstr "uno de los argumentos %s es necesario"

#: argparse.py:2396
msgid "expected one argument"
msgstr "se espera un argumento"

#: argparse.py:2397
msgid "expected at most one argument"
msgstr "se espera a lo sumo un argumento"

#: argparse.py:2398
msgid "expected at least one argument"
msgstr "se espera al menos un argumento"

#: argparse.py:2402
#, python-format
msgid "expected %s argument"
msgid_plural "expected %s arguments"
msgstr[0] "se espera el argumento %s"
msgstr[1] "se esperan los argumentos %s"

#: argparse.py:2512
#, python-format
msgid "unexpected option string: %s"
msgstr "literal de opción inesperado: %s"

#: argparse.py:2660
#, python-format
msgid "invalid %(type)s value: %(value)r"
msgstr "valor %(type)s inválido: %(value)r"

#: argparse.py:2678
#, python-format
msgid "invalid choice: %(value)r (choose from %(choices)s)"
msgstr "opción inválida: %(value)r (elegir entre %(choices)s)"

#: argparse.py:2686
#, python-format
msgid ""
"invalid choice: %(value)r, maybe you meant %(closest)r? (choose from "
"%(choices)s)"
msgstr "Opción inválida: %(value)r, ¿quizás quisiste decir %(closest)r? (elige entre %(choices)s)"

#: argparse.py:2771
#, python-format
msgid "%(prog)s: error: %(message)s\n"
msgstr "%(prog)s: error: %(message)s\n"

#: argparse.py:2775
#, python-format
msgid "%(prog)s: warning: %(message)s\n"
msgstr "%(prog)s: aviso: %(message)s\n"
